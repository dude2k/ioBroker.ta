{
  "name": "iobroker.ta",
  "version": "0.0.4",
  "description": "Read-only ioBroker adapter for the Technische Alternative C.M.I. JSON API.",
  "author": {
    "name": "dude2k",
    "email": "placeholder@example.com"
  },
  "contributors": [],
  "homepage": "https://github.com/dude2k/ioBroker.ta",
  "license": "MIT",
  "keywords": [
    "iobroker",
    "technische alternative",
    "ta",
    "cmi",
    "uvr16x2",
    "heating",
    "solar",
    "can-bus"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dude2k/ioBroker.ta.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/iobroker": "npm:@iobroker/types@^7.2.2",
    "@types/mocha": "^10.0.10",
    "@types/sinon-chai": "^4.0.0",
    "@types/node": "^20.19.43",
    "chai": "^5.3.3",
    "chai-as-promised": "^8.0.2",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "rimraf": "^6.1.3",
    "sinon-chai": "^4.0.1",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:ts": "npm run test:unit",
    "test:unit": "mocha --config test/mocharc.custom.json \"src/**/*.test.ts\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha --config test/mocharc.custom.json \"test/integration/**/*.test.ts\"",
    "test:adapter": "mocha test/integration.js --exit",
    "test": "npm run test:unit && npm run test:integration && npm run test:package",
    "check": "tsc --noEmit",
    "coverage": "nyc npm run test:ts",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server"
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true
  },
  "bugs": {
    "url": "https://github.com/dude2k/ioBroker.ta/issues"
  },
  "readmeFilename": "README.md"
}
